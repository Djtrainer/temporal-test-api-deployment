# Temporal frontend address (host:port)
TEMPORAL_HOST=localhost:7233

# Namespace — "default" is what temporalio/auto-setup creates
TEMPORAL_NAMESPACE=default

# Set to "true" when connecting to a TLS-fronted server (e.g. Cloud Run)
TEMPORAL_TLS=false

# Task queue name — must match between worker and client
TEMPORAL_TASK_QUEUE=demo-task-queue
